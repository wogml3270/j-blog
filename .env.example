# e.g. https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# 최신 키 이름 (권장)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# 레거시 키 이름(선택). 위 키가 없을 때 fallback으로 사용
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 서버 전용 (절대 클라이언트 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=

# 관리자 업로드 이미지 버킷(권장)
SUPABASE_STORAGE_BUCKET=project-thumbnails

# 레거시 이름(선택). 위 키가 없을 때 fallback으로 사용
SUPABASE_PROJECT_THUMBNAIL_BUCKET=project-thumbnails

ADMIN_ALLOWED_EMAILS=

# 로컬에서 관리자 저장 시 프로덕션 캐시까지 함께 무효화하려면 설정
# 예: https://j-fe-blog.vercel.app
REVALIDATE_TARGET_URL=
REVALIDATE_SECRET=

RESEND_API_KEY=
SITE_CONTACT_TO_EMAIL=
SITE_CONTACT_FROM_EMAIL=
